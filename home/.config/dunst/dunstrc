# ~/.config/dunst/dunstrc
# Void Space theme — dunst 1.5.x

[global]
    # Geometry: WIDTHxHEIGHT-X+Y  (-X = da direita, +Y = do topo)
    geometry         = "380x5-12+12"

    indicate_hidden  = yes
    transparency     = 5
    padding          = 12
    horizontal_padding = 14
    frame_width      = 2
    frame_color      = "#323c4d"
    separator_height = 2
    separator_color  = frame

    font             = Ubuntu Mono Nerd Font Mono 11
    markup           = full
    format           = "<b>%s</b>\n%b"
    alignment        = left
    show_age_threshold = 60
    word_wrap        = yes
    stack_duplicates = true
    hide_duplicate_count = false
    show_indicators  = yes

    icon_position    = left
    max_icon_size    = 48
    icon_path        = /usr/share/icons/Yaru/48x48/status:/usr/share/icons/Yaru/48x48/apps:/usr/share/icons/Yaru/48x48/devices:/usr/share/icons/Yaru/scalable/status:/usr/share/icons/Yaru/scalable/apps:/usr/share/pixmaps

    sticky_history   = yes
    history_length   = 30

    dmenu            = /usr/bin/rofi -dmenu -p "notifications:"
    browser          = /usr/bin/xdg-open

    title            = Dunst
    class            = Dunst

    mouse_left_click   = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click  = close_all

    close     = ctrl+space
    close_all = ctrl+shift+space
    history   = ctrl+grave
    context   = ctrl+shift+period

[urgency_low]
    background  = "#1a1f28"
    foreground  = "#5f7090"
    frame_color = "#232936"
    timeout     = 4

[urgency_normal]
    background  = "#1a1f28"
    foreground  = "#99a7be"
    frame_color = "#618bc2"
    timeout     = 8

[urgency_critical]
    background  = "#1a1f28"
    foreground  = "#c68b8f"
    frame_color = "#c68b8f"
    timeout     = 0
